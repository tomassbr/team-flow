{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@team-flow/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@team-flow/shared/*": [
        "../../packages/shared/src/*"
      ],
      "@team-flow/api-client": [
        "../../packages/api-client/src/index.ts"
      ],
      "@team-flow/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts"
  ]
}
